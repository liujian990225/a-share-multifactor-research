project:
  name: a_share_multifactor_csv
  random_seed: 42

data:
  source: csv
  csv:
    prices_path: data/raw/prices.csv
    fundamentals_path: data/raw/fundamentals.csv
    benchmark_path: data/raw/benchmark.csv
    membership_path: data/raw/membership.csv

backtest:
  start_date: "2016-01-01"
  end_date: "2024-12-31"
  rebalance_freq: M
  execution_lag: 1
  top_n: 30
  top_pct: null
  transaction_cost_bps: 10
  benchmark_name: CSI300
  industry_neutral_selection: true
  min_listed_days: 180
  min_avg_amount: 20000000

factor:
  neutralize: true
  neutralize_size: true
  winsorize_method: mad
  mad_n: 3.0
  ic_lookback: 12
  min_ic_obs: 6
  quantiles: 5
  category_weights:
    value: 0.25
    quality: 0.25
    momentum: 0.20
    low_volatility: 0.15
    liquidity: 0.15

analysis:
  sensitivity:
    top_n_list: [20, 30, 50]
    cost_bps_list: [5, 10, 20]
  regime:
    lookback_days: 120
    bull_threshold: 0.10
    bear_threshold: -0.10

reports:
  output_dir: reports/csv_run
  save_figures: true
  save_csv: true
